generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vehicle {
  id           Int     @id @default(autoincrement())
  groupId      String
  slug         String  @unique
  vin          String?
  licensePlate String?
  year         Int
  make         String
  model        String
  category     String
  color        String
  seats        Int
  transmission String
  pricePerDay  Int
  image        String
  description  String
  isActive     Boolean @default(true)

  bookings Booking[]
  blocks   VehicleBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([category])
  @@index([isActive])
}

model Customer {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique
  phone    String

  notes String?

  // 🔥 NEW
  verificationStatus String    @default("unverified") // unverified | pending | approved | rejected
  verifiedAt         DateTime?

  bookings  Booking[]
  documents CustomerDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([verificationStatus])
}

model Booking {
  id         Int @id @default(autoincrement())
  vehicleId  Int
  customerId Int

  fullName String
  email    String
  phone    String

  pickupAt DateTime
  returnAt DateTime

  status String @default("pending") // pending | confirmed | cancelled

  // 🔥 NEW
  verificationStatus String @default("pending") // pending | approved | rejected
  paymentStatus      String @default("unpaid") // unpaid | pending | paid | refunded

  rejectionReason         String?
  lastAdminMessageSubject String?
  lastAdminMessageBody    String?
  lastAdminMessagedAt     DateTime?

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  customerDocuments CustomerDocument[]

  @@index([vehicleId])
  @@index([customerId])
  @@index([pickupAt, returnAt])
  @@index([status])
  @@index([verificationStatus])
  @@index([paymentStatus])
}

model VehicleBlock {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  startAt   DateTime
  endAt     DateTime
  reason    String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([startAt, endAt])
}

model CustomerDocument {
  id         Int  @id @default(autoincrement())
  customerId Int
  bookingId  Int?

  documentType String // license | insurance
  filePath     String
  originalName String
  mimeType     String?

  status     String    @default("pending") // pending | approved | rejected
  notes      String?
  reviewedAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([bookingId])
  @@index([documentType])
  @@index([status])
}
