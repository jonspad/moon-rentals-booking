generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vehicle {
  id           Int            @id @default(autoincrement())
  groupId      String
  slug         String         @unique
  vin          String?
  licensePlate String?
  year         Int
  make         String
  model        String
  category     String
  color        String
  seats        Int
  transmission String
  pricePerDay  Int
  image        String
  description  String
  isActive     Boolean        @default(true)
  bookings     Booking[]
  blocks       VehicleBlock[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([groupId])
  @@index([category])
  @@index([isActive])
}

model Customer {
  id        Int       @id @default(autoincrement())
  fullName  String
  email     String    @unique
  phone     String
  notes     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([fullName])
}

model Booking {
  id                      Int       @id @default(autoincrement())
  vehicleId               Int
  customerId              Int
  fullName                String
  email                   String
  phone                   String
  pickupAt                DateTime
  returnAt                DateTime
  status                  String    @default("pending")
  rejectionReason         String?
  lastAdminMessageSubject String?
  lastAdminMessageBody    String?
  lastAdminMessagedAt     DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([customerId])
  @@index([pickupAt, returnAt])
  @@index([status])
}

model VehicleBlock {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([startAt, endAt])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
