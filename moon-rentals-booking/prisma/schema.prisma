generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vehicle {
  id            Int                   @id @default(autoincrement())
  groupId       String
  slug          String                @unique
  vin           String?
  licensePlate  String?
  year          Int
  make          String
  model         String
  category      String
  color         String
  seats         Int
  transmission  String
  pricePerDay   Int
  image         String
  description   String
  internalNotes String?
  isActive      Boolean               @default(true)
  bookings      Booking[]
  blocks        VehicleBlock[]
  savedGroups   VehicleGroupVehicle[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([groupId])
  @@index([category])
  @@index([isActive])
}

model Customer {
  id                       Int                @id @default(autoincrement())
  fullName                 String
  email                    String             @unique
  phone                    String
  notes                    String?
  verificationStatus       String             @default("unverified")
  manualVerificationStatus String?
  verifiedAt               DateTime?
  bookings                 Booking[]
  documents                CustomerDocument[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([fullName])
  @@index([verificationStatus])
  @@index([manualVerificationStatus])
}

model Booking {
  id                      Int                 @id @default(autoincrement())
  vehicleId               Int
  customerId              Int
  fullName                String
  email                   String
  phone                   String
  pickupAt                DateTime
  returnAt                DateTime
  status                  String              @default("pending")
  verificationStatus      String              @default("pending")
  paymentStatus           String              @default("unpaid")
  pricePerDaySnapshot     Int
  totalDaysSnapshot       Int
  totalPriceSnapshot      Int
  discountAmount          Int                 @default(0)
  extraFeeAmount          Int                 @default(0)
  finalPriceOverride      Int?
  pricingNote             String?
  rejectionReason         String?
  lastAdminMessageSubject String?
  lastAdminMessageBody    String?
  lastAdminMessagedAt     DateTime?
  messageLogs             BookingMessageLog[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  vehicle   Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  customer  Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  documents CustomerDocument[]

  @@index([vehicleId])
  @@index([customerId])
  @@index([pickupAt, returnAt])
  @@index([status])
  @@index([verificationStatus])
  @@index([paymentStatus])
}

model BookingMessageLog {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  kind           String
  template       String
  recipientEmail String
  subject        String
  body           String
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([kind])
  @@index([template])
  @@index([sentAt])
}

model VehicleGroup {
  id          Int                   @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean               @default(true)
  vehicles    VehicleGroupVehicle[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([name])
  @@index([isActive])
}

model VehicleGroupVehicle {
  id             Int      @id @default(autoincrement())
  vehicleGroupId Int
  vehicleId      Int
  createdAt      DateTime @default(now())

  vehicleGroup VehicleGroup @relation(fields: [vehicleGroupId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@unique([vehicleGroupId, vehicleId])
  @@index([vehicleGroupId])
  @@index([vehicleId])
}

model VehicleBlockGroup {
  id        Int            @id @default(autoincrement())
  name      String?
  reason    String?
  startAt   DateTime
  endAt     DateTime
  blocks    VehicleBlock[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([startAt, endAt])
  @@index([name])
}

model VehicleBlock {
  id           Int      @id @default(autoincrement())
  vehicleId    Int
  blockGroupId Int?
  startAt      DateTime
  endAt        DateTime
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicle    Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  blockGroup VehicleBlockGroup? @relation(fields: [blockGroupId], references: [id], onDelete: Cascade)

  @@unique([blockGroupId, vehicleId])
  @@index([vehicleId])
  @@index([blockGroupId])
  @@index([startAt, endAt])
}

model CustomerDocument {
  id           Int       @id @default(autoincrement())
  customerId   Int
  bookingId    Int?
  documentType String
  filePath     String
  originalName String
  mimeType     String?
  status       String    @default("pending")
  notes        String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([bookingId])
  @@index([documentType])
  @@index([status])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminAction {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}
